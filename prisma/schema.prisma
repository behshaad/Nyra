generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PublicationStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE
  FILL_IN_BLANK
  WORD_ORDERING
}

enum SkillKind {
  REGULAR
  UNIT_CHECKPOINT
  FINAL_TEST
}

enum ResourceType {
  BOOK
  VIDEO
  AUDIO_LESSON
  EXTERNAL_LINK
  GRAMMAR_RESOURCE
  READING_MATERIAL
  LEARNING_GUIDE
}

enum InterfaceTheme {
  SYSTEM
  LIGHT
  DARK
}

enum LearningSessionStatus {
  ACTIVE
  COMPLETED
}

enum QuestionAttemptResult {
  CORRECT
  INCORRECT
}

enum ProgressEventType {
  SKILL_STARTED
  QUESTION_ANSWERED
  SKILL_COMPLETED
  XP_AWARDED
  FLASHCARD_REVIEWED
}

enum FlashcardDeckOwnerType {
  ADMIN
  LEARNER
}

enum FlashcardDifficulty {
  EASY
  MEDIUM
  HARD
}

enum FlashcardReviewResult {
  KNOWN
  UNKNOWN
}

model Course {
  id                String   @id @default(uuid())
  slug              String   @unique
  title             String
  sourceLanguage    String
  targetLanguage    String
  interfaceLanguage String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  levels Level[]
}

model Level {
  id        String   @id @default(uuid())
  courseId  String
  order     Int
  label     String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  units  Unit[]

  @@unique([courseId, label])
  @@unique([courseId, order])
}

model Unit {
  id        String   @id @default(uuid())
  levelId   String
  order     Int
  slug      String   @unique
  title     String
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  level          Level           @relation(fields: [levelId], references: [id], onDelete: Cascade)
  skills         Skill[]
  resources      Resource[]
  flashcardDecks FlashcardDeck[]

  @@unique([levelId, order])
}

model Skill {
  id                String            @id @default(uuid())
  unitId            String
  order             Int
  slug              String            @unique
  title             String
  description       String
  kind              SkillKind         @default(REGULAR)
  xp                Int               @default(80)
  passingScore      Int?
  requeueIncorrect  Boolean           @default(true)
  publicationStatus PublicationStatus @default(DRAFT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  unit             Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  questions        Question[]
  learningSessions LearningSession[]
  progressEvents   ProgressEvent[]
  resources        Resource[]

  @@unique([unitId, order])
}

model Question {
  id                String            @id @default(uuid())
  skillId           String
  order             Int
  type              QuestionType
  prompt            String
  helper            String?
  choices           Json?
  correctAnswer     String
  explanation       String
  required          Boolean           @default(true)
  publicationStatus PublicationStatus @default(PUBLISHED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  skill    Skill             @relation(fields: [skillId], references: [id], onDelete: Cascade)
  attempts QuestionAttempt[]
  suggestedFlashcards QuestionSuggestedFlashcard[]

  @@unique([skillId, order])
}

model LearnerProfile {
  id                 String   @id @default(uuid())
  authUserId         String?  @unique
  displayName        String
  sourceLanguage     String
  targetLanguage     String
  interfaceLanguage  String
  interfaceTheme     InterfaceTheme @default(SYSTEM)
  currentLevel       String
  dailyGoalMinutes   Int
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  learningSessions LearningSession[]
  progressEvents   ProgressEvent[]
  flashcardDecks   FlashcardDeck[]
  flashcardReviewStates FlashcardReviewState[]
}

model LearningSession {
  id               String                @id @default(uuid())
  learnerProfileId String
  skillId          String
  status           LearningSessionStatus @default(ACTIVE)
  questionQueue    Json
  startedAt        DateTime              @default(now())
  completedAt      DateTime?
  xpAwardedAt      DateTime?
  updatedAt        DateTime              @updatedAt

  learnerProfile LearnerProfile    @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  skill          Skill             @relation(fields: [skillId], references: [id], onDelete: Cascade)
  attempts       QuestionAttempt[]
  progressEvents ProgressEvent[]
}

model QuestionAttempt {
  id                String                @id @default(uuid())
  learningSessionId String
  questionId        String
  submittedAnswer   String
  result            QuestionAttemptResult
  feedback          String
  createdAt         DateTime              @default(now())

  learningSession LearningSession @relation(fields: [learningSessionId], references: [id], onDelete: Cascade)
  question        Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ProgressEvent {
  id                String            @id @default(uuid())
  learnerProfileId  String
  learningSessionId String?
  skillId           String?
  type              ProgressEventType
  xp                Int?
  metadata          Json?
  createdAt         DateTime          @default(now())

  learnerProfile  LearnerProfile   @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  learningSession LearningSession? @relation(fields: [learningSessionId], references: [id], onDelete: SetNull)
  skill           Skill?           @relation(fields: [skillId], references: [id], onDelete: SetNull)
}

model Resource {
  id                String            @id @default(uuid())
  slug              String            @unique
  title             String
  description       String
  type              ResourceType
  levelLabel        String
  language          String            @default("fa")
  thumbnailIcon     String            @default("book-open")
  metadata          Json?
  content           String
  url               String?
  publicationStatus PublicationStatus @default(DRAFT)
  unitId            String?
  skillId           String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  unit  Unit?  @relation(fields: [unitId], references: [id], onDelete: SetNull)
  skill Skill? @relation(fields: [skillId], references: [id], onDelete: SetNull)
}

model FlashcardDeck {
  id                String                 @id @default(uuid())
  slug              String                 @unique
  title             String
  description       String
  levelLabel        String
  category          String
  ownerType         FlashcardDeckOwnerType @default(ADMIN)
  publicationStatus PublicationStatus      @default(DRAFT)
  learnerProfileId  String?
  unitId            String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  learnerProfile LearnerProfile? @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  unit           Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  flashcards     Flashcard[]
}

model Flashcard {
  id             String              @id @default(uuid())
  deckId         String
  order          Int
  front          String
  back           String
  article        String?
  example        String
  exampleMeaning String
  pronunciation         String?
  pronunciationAudioUrl String?
  difficulty            FlashcardDifficulty @default(MEDIUM)
  publicationStatus     PublicationStatus    @default(PUBLISHED)
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviewStates FlashcardReviewState[]
  suggestedByQuestions QuestionSuggestedFlashcard[]

  @@unique([deckId, order])
}

model QuestionSuggestedFlashcard {
  id          String   @id @default(uuid())
  questionId  String
  flashcardId String
  order       Int
  createdAt   DateTime @default(now())

  question  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([questionId, flashcardId])
  @@unique([questionId, order])
}

model FlashcardReviewState {
  id               String   @id @default(uuid())
  learnerProfileId String
  flashcardId      String
  intervalStep     Int      @default(0)
  dueAt            DateTime @default(now())
  lastReviewedAt   DateTime?
  reviewCount      Int      @default(0)
  knownCount       Int      @default(0)
  unknownCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  learnerProfile LearnerProfile @relation(fields: [learnerProfileId], references: [id], onDelete: Cascade)
  flashcard      Flashcard      @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([learnerProfileId, flashcardId])
  @@index([learnerProfileId, dueAt])
}
